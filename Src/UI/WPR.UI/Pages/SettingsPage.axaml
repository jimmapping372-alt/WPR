<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="540"
			 xmlns:p="clr-namespace:WPR.UI.Properties"
             x:Class="WPR.UI.Pages.SettingsPage">
	<ScrollViewer>
		<StackPanel Margin="20" Spacing="6">

			<!-- Gamer Profile section -->
			<TextBlock Text="{x:Static p:Resources.GamerProfile}"
			           FontSize="16" FontWeight="SemiBold"
			           Foreground="White"
			           Margin="0,0,0,6"/>
			<Border BorderBrush="#3FFFFFFF" BorderThickness="1" CornerRadius="3" Padding="12">
				<StackPanel Spacing="10">
					<Grid VerticalAlignment="Center">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="160" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" Padding="0,0,10,0" VerticalContentAlignment="Center" Foreground="White">GamerTag</Label>
						<TextBox Name="gamerTagTextBox" Grid.Column="1"
						         HorizontalAlignment="Stretch"
						         Watermark="{x:Static p:Resources.EnterYourGamerTag}" />
					</Grid>

					<Grid VerticalAlignment="Center">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="160" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" Padding="0,0,10,0"
						       VerticalContentAlignment="Center"
						       Content="{x:Static p:Resources.GamerPicture}"
						       Foreground="White"/>
						<Border Grid.Column="1"
						        Width="48" Height="48"
						        Margin="0,0,10,0"
						        CornerRadius="3"
						        BorderBrush="#7FFFFFFF" BorderThickness="1"
						        Background="#33FFFFFF">
							<Image Name="gamerPictureImage" Stretch="UniformToFill"/>
						</Border>
						<TextBlock Name="gamerPicturePathText"
						           Grid.Column="2"
						           VerticalAlignment="Center"
						           TextTrimming="CharacterEllipsis"
						           Foreground="#BFFFFFFF"
						           Text="{x:Static p:Resources.GamerPictureNone}"/>
						<Button Name="gamerPictureBrowseBtn"
						        Grid.Column="3"
						        Margin="10,0,0,0"
						        Content="{x:Static p:Resources.GamerPictureBrowse}"/>
						<Button Name="gamerPictureClearBtn"
						        Grid.Column="4"
						        Margin="6,0,0,0"
						        Content="{x:Static p:Resources.GamerPictureClear}"/>
					</Grid>
					<TextBlock Text="{x:Static p:Resources.GamerPictureHint}"
					           Foreground="#BFFFFFFF" FontSize="11" TextWrapping="Wrap"
					           Margin="160,0,0,0"/>

					<!-- Default avatars strip — populated programmatically from
					     WPR.Common.GamerPictureDefaults in code-behind. Each
					     thumbnail is a clickable button; selecting one sets the
					     config to default:<id>. -->
					<StackPanel Orientation="Horizontal" Margin="160,4,0,0" Spacing="6"
					            Name="gamerPictureDefaultsPanel"/>

					<Grid VerticalAlignment="Center">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="160" />
							<ColumnDefinition Width="Auto" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0" Padding="0,0,10,0"
						       VerticalContentAlignment="Center"
						       Content="{x:Static p:Resources.HighlightColor}"
						       Foreground="White"/>
						<!-- live preview swatch — updated programmatically when selection changes -->
						<Border Name="highlightColorSwatch"
						        Grid.Column="1"
						        Width="28" Height="28"
						        Margin="0,0,10,0"
						        CornerRadius="3"
						        BorderBrush="#7FFFFFFF" BorderThickness="1"
						        Background="#FF1BA1E2"/>
						<ComboBox Name="highlightColorBox"
						          Grid.Column="2"
						          HorizontalAlignment="Stretch"
						          VerticalAlignment="Center">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<StackPanel Orientation="Horizontal" Spacing="10">
										<Border Width="20" Height="20" CornerRadius="2"
										        BorderBrush="#7FFFFFFF" BorderThickness="1"
										        Background="{Binding Brush}"/>
										<TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="White"/>
									</StackPanel>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</Grid>
					<TextBlock Text="{x:Static p:Resources.HighlightColorHint}"
					           Foreground="#BFFFFFFF" FontSize="11" TextWrapping="Wrap"
					           Margin="160,0,0,0"/>
				</StackPanel>
			</Border>

			<!-- Existing path-related settings -->
			<Grid VerticalAlignment="Center" Margin="0,20,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*" />
					<ColumnDefinition Width="5*" />
					<ColumnDefinition Width="1*" />
				</Grid.ColumnDefinitions>

				<Label Padding="0,0,10,0" Grid.Column="0" Content="{x:Static p:Resources.DataStoragePath}" VerticalContentAlignment="Center"/>
				<TextBox Grid.Column="1" Name="dataStoragePathText" IsReadOnly="True" />
				<Button Grid.Column="2" HorizontalAlignment="Right" Name="dataStoragePathBrowse" Content="{x:Static p:Resources.BrowsePath}" />
			</Grid>
			<Button Name="restoreDefaultStoragePathBtn" Margin="0,10,0,0" HorizontalAlignment="Right" Content="{x:Static p:Resources.RestoreDefaultStorage}"/>

			<Grid VerticalAlignment="Center" Margin="0,20,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="1*" />
					<ColumnDefinition Width="5*" />
					<ColumnDefinition Width="1*" />
				</Grid.ColumnDefinitions>

				<Label Padding="0,0,10,0" Grid.Column="0" Content="{x:Static p:Resources.GameLibraryPath}" VerticalContentAlignment="Center"/>
				<TextBox Grid.Column="1" Name="gameLibraryPathText" IsReadOnly="True" Watermark="{x:Static p:Resources.GameLibraryPathHint}" />
				<Button Grid.Column="2" HorizontalAlignment="Right" Name="gameLibraryPathBrowse" Content="{x:Static p:Resources.BrowsePath}" />
			</Grid>
			<Button Name="clearGameLibraryPathBtn" Margin="0,10,0,0" HorizontalAlignment="Right" Content="{x:Static p:Resources.ClearGameLibraryPath}"/>
		</StackPanel>
	</ScrollViewer>
</UserControl>
