<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:WPR.UI"
             xmlns:dialogHost="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             x:Class="WPR.UI.App">
  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <Color x:Key="WprBg">#1b2838</Color>
      <Color x:Key="WprBgDeep">#10151c</Color>
      <Color x:Key="WprSidebar">#171a21</Color>
      <Color x:Key="WprPanel">#22384f</Color>
      <Color x:Key="WprPanelHi">#3c5d7a</Color>
      <Color x:Key="WprPanelBorder">#2a3b4f</Color>
      <Color x:Key="WprAccent">#66c0f4</Color>
      <Color x:Key="WprAccentDim">#417a9b</Color>
      <Color x:Key="WprPlay">#5ba32b</Color>
      <Color x:Key="WprPlayHover">#71c136</Color>
      <Color x:Key="WprText">#c7d5e0</Color>
      <Color x:Key="WprTextDim">#8f98a0</Color>
      <Color x:Key="WprTextStrong">#ffffff</Color>

      <SolidColorBrush x:Key="WprBgBrush" Color="{StaticResource WprBg}"/>
      <SolidColorBrush x:Key="WprBgDeepBrush" Color="{StaticResource WprBgDeep}"/>
      <SolidColorBrush x:Key="WprSidebarBrush" Color="{StaticResource WprSidebar}"/>
      <SolidColorBrush x:Key="WprPanelBrush" Color="{StaticResource WprPanel}"/>
      <SolidColorBrush x:Key="WprPanelHiBrush" Color="{StaticResource WprPanelHi}"/>
      <SolidColorBrush x:Key="WprPanelBorderBrush" Color="{StaticResource WprPanelBorder}"/>
      <SolidColorBrush x:Key="WprAccentBrush" Color="{StaticResource WprAccent}"/>
      <SolidColorBrush x:Key="WprAccentDimBrush" Color="{StaticResource WprAccentDim}"/>
      <SolidColorBrush x:Key="WprPlayBrush" Color="{StaticResource WprPlay}"/>
      <SolidColorBrush x:Key="WprPlayHoverBrush" Color="{StaticResource WprPlayHover}"/>
      <SolidColorBrush x:Key="WprTextBrush" Color="{StaticResource WprText}"/>
      <SolidColorBrush x:Key="WprTextDimBrush" Color="{StaticResource WprTextDim}"/>
      <SolidColorBrush x:Key="WprTextStrongBrush" Color="{StaticResource WprTextStrong}"/>

      <LinearGradientBrush x:Key="WprWindowBackdrop" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Color="#1b2838" Offset="0.0"/>
        <GradientStop Color="#171a21" Offset="1.0"/>
      </LinearGradientBrush>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme/>
    <dialogHost:DialogHostStyles/>

    <Style Selector="Label">
      <Setter Property="Foreground" Value="{StaticResource WprTextBrush}" />
    </Style>

    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="32"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource WprTextStrongBrush}"/>
    </Style>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource WprTextStrongBrush}"/>
    </Style>
    <Style Selector="TextBlock.eyebrow">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource WprTextDimBrush}"/>
      <Setter Property="LetterSpacing" Value="2"/>
    </Style>
    <Style Selector="TextBlock.body">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="{StaticResource WprTextBrush}"/>
      <Setter Property="LineHeight" Value="20"/>
    </Style>
    <Style Selector="TextBlock.dim">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{StaticResource WprTextDimBrush}"/>
    </Style>

    <Style Selector="Button.play">
      <Setter Property="Background" Value="{StaticResource WprPlayBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Padding" Value="32,12"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.play:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource WprPlayHoverBrush}"/>
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="#2a475e"/>
      <Setter Property="Foreground" Value="{StaticResource WprTextBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#3c5d7a"/>
    </Style>

    <Style Selector="TextBox.search">
      <Setter Property="Background" Value="#0e151c"/>
      <Setter Property="Foreground" Value="{StaticResource WprTextBrush}"/>
      <Setter Property="BorderBrush" Value="#0e151c"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBox.search:focus">
      <Setter Property="BorderBrush" Value="{StaticResource WprAccentBrush}"/>
    </Style>

    <Style Selector="ListBox.library">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="ListBox.library ListBoxItem">
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="Margin" Value="4,1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="ListBox.library ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#22384f"/>
    </Style>
    <Style Selector="ListBox.library ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4f6e"/>
    </Style>
    <Style Selector="ListBox.library ListBoxItem:selected:focus /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a4f6e"/>
    </Style>

    <Style Selector="TabControl.sidebar">
      <Setter Property="Background" Value="{StaticResource WprSidebarBrush}"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="TabControl.sidebar TabItem">
      <Setter Property="Foreground" Value="{StaticResource WprTextDimBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="MinHeight" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="TabControl.sidebar TabItem:pointerover">
      <Setter Property="Foreground" Value="{StaticResource WprTextBrush}"/>
    </Style>
    <Style Selector="TabControl.sidebar TabItem:selected">
      <Setter Property="Foreground" Value="{StaticResource WprAccentBrush}"/>
    </Style>
  </Application.Styles>
</Application>
