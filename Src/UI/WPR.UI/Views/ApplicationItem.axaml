<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Width="{Binding IconSize}" Height="{Binding Height}"
             x:Class="WPR.UI.Views.ApplicationView">
	<Grid HorizontalAlignment="Center" Background="Transparent" ToolTip.Tip="{Binding Tooltip}">
		<Grid.RowDefinitions>
			<RowDefinition Height="90"/>
			<RowDefinition/>
		</Grid.RowDefinitions>

		<Grid.ContextMenu>
			<ContextMenu>
				<MenuItem Header="Run" Command="{Binding RunAppCommand}"/>
				<MenuItem Header="Uninstall" Command="{Binding UninstallAppCommand}"/>
			</ContextMenu>
		</Grid.ContextMenu>

		<Grid Grid.Row="0" Margin="0,10" Width="{Binding IconSize}" Height="{Binding IconSize}">
            <Image Width="{Binding IconSize}" 
                   Height="{Binding IconSize}" 
                   Source="{Binding Icon}" />
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Top" 
                        Margin="9,9,9,9" Spacing="9">
                <Button Width="32" Height="32" Command="{Binding RunAppCommand}" 
                        ToolTip.Tip="Run" 
                        Background="#DDFFFFFF" 
                        Padding="0" Margin="0">
                    <TextBlock FontSize="18" Text="▶" 
                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Width="32" Height="32" Command="{Binding UninstallAppCommand}" 
                        ToolTip.Tip="Uninstall" 
                        Background="#DDFFFFFF" 
                        Padding="0" Margin="0">
                    <TextBlock FontSize="18" Text="🗑" 
                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
		<Label Grid.Row="1" Margin="0,5,0,10">
            <TextBlock HorizontalAlignment="Center" Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" />
        </Label>
	</Grid>
</UserControl>
